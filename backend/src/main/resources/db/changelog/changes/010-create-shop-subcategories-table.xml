<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="010-create-shop-subcategories-table" author="janesjeans">
        <createTable tableName="shop_subcategories">
            <column name="id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="shop_subcategories"
            baseColumnNames="category_id"
            constraintName="fk_shop_subcategories_category"
            referencedTableName="shop_categories"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <createIndex tableName="shop_subcategories" indexName="idx_shop_subcategories_category">
            <column name="category_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
